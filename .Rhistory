stopifnot(sum(is.na(panel_base$organic_matter)) == 0)
soil_vars <- c("pH", "organic_matter", "total_nitrogen", "cec", "clay", "sand")
re_weather <- c("days_hot_crit_gs", "days_cold_crit_gs",
"sum_heat_pos_gs", "sum_cold_neg_gs",
"total_precip_gs", "mean_wind_gs",
"mean_soil_moisture_pct", "days_drought")
re_formula <- as.formula(paste(
"yield_cpha ~",
paste(c(re_weather, soil_vars, "log_sown", "war_east"), collapse = " + "),
"+ (1 | region) + (1 | year)"
))
m_re <- lme4::lmer(re_formula, data = panel_base, REML = FALSE)
panel_base <- panel_base %>%
dplyr::select(-dplyr::starts_with("pH."))
soil_vars <- c("pH", "organic_matter", "total_nitrogen", "cec", "clay", "sand")
re_weather <- c("days_hot_crit_gs", "days_cold_crit_gs",
"sum_heat_pos_gs", "sum_cold_neg_gs",
"total_precip_gs", "mean_wind_gs",
"mean_soil_moisture_pct", "days_drought")
re_formula <- as.formula(paste(
"yield_cpha ~",
paste(c(re_weather, soil_vars, "log_sown", "war_east"), collapse = " + "),
"+ (1 | region) + (1 | year)"
))
m_re <- lme4::lmer(re_formula, data = panel_base, REML = FALSE)
mundlak_vars <- re_weather
mundlak_means <- panel_base |>
group_by(region) |>
summarise(
across(all_of(mundlak_vars),
~ mean(.x, na.rm = TRUE),
.names = "{.col}_mean"),
.groups = "drop"
)
panel_mundlak <- panel_base |>
left_join(mundlak_means, by = "region")
mundlak_mean_cols <- paste0(mundlak_vars, "_mean")
mundlak_formula <- as.formula(paste(
"yield_cpha ~",
paste(c(re_weather, soil_vars, mundlak_mean_cols,
"log_sown", "war_east"), collapse = " + "),
"+ (1 | region) + (1 | year)"
))
m_mundlak <- lmer(mundlak_formula, data = panel_mundlak, REML = FALSE)
