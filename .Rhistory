print(intersect(panel_base$region, soil_raw$region))
soil_vars <- c("pH", "organic_matter", "total_nitrogen", "cec", "clay", "sand")
re_weather <- c("days_hot_crit_gs", "days_cold_crit_gs",
"sum_heat_pos_gs", "sum_cold_neg_gs",
"total_precip_gs", "mean_wind_gs",
"mean_soil_moisture_pct", "days_drought")
re_formula <- as.formula(paste(
"yield_cpha ~",
paste(c(re_weather, soil_vars, "log_sown", "war_east"), collapse = " + "),
"+ (1 | region) + (1 | year)"
))
m_re <- lme4::lmer(re_formula, data = panel_base, REML = FALSE)
oblast_map <- c(
"Vinnytska"        = "Вінницька",
"Volynska"         = "Волинська",
"Dnipropetrovska"  = "Дніпропетровська",
"Donetska"         = "Донецька",
"Zhytomyrska"      = "Житомирська",
"Zakarpatska"      = "Закарпатська",
"Zaporizka"        = "Запорізька",
"Ivano_Frankivska" = "Івано_Франківська",
"Kyivska"          = "Київська",
"Kirovohradska"    = "Кіровоградська",
"Luhanska"         = "Луганська",
"Lvivska"          = "Львівська",
"Mykolaivska"      = "Миколаївська",
"Odeska"           = "Одеська",
"Poltavska"        = "Полтавська",
"Rivnenska"        = "Рівненська",
"Sumska"           = "Сумська",
"Ternopilska"      = "Тернопільська",
"Kharkivska"       = "Харківська",
"Khersonska"       = "Херсонська",
"Khmelnytska"      = "Хмельницька",
"Cherkaska"        = "Черкаська",
"Chernivetska"     = "Чернівецька",
"Chernihivska"     = "Чернігівська"
)
soil_raw <- read_csv("soil_data.csv", show_col_types = FALSE) |>
mutate(region = oblast_map[oblast]) |>
dplyr::select(-oblast)
# Verify translation worked
cat("NAs in soil region after mapping:", sum(is.na(soil_raw$region)), "\n")
cat("panel_base region sample:", head(unique(panel_base$region)), "\n")
cat("soil_raw region sample:", head(unique(soil_raw$region)), "\n")
panel_base <- panel_base |>
left_join(soil_raw, by = "region")
cat("Non-NA pH values after join:", sum(!is.na(panel_base$pH)), "\n")
panel_base$region <- trimws(panel_base$region)
soil_raw$region   <- trimws(soil_raw$region)
# Force same encoding
panel_base$region <- enc2utf8(panel_base$region)
soil_raw$region   <- enc2utf8(soil_raw$region)
panel_base <- panel_base |>
left_join(soil_raw, by = "region")
cat("Non-NA pH values after join:", sum(!is.na(panel_base$pH)), "\n")
# Extra diagnostic - check if any rows actually matched
cat("Matched regions:\n")
print(intersect(panel_base$region, soil_raw$region))
names(panel_base)
tinytex::install_tinytex()
