)
}
# ── Helper: one heatmap tile ────────────────────────────────
make_tile <- function(df, metric, palette, direction = 1,
title, subtitle) {
ggplot(df, aes(x = year, y = region, fill = .data[[metric]])) +
geom_tile(colour = "white", linewidth = 0.35) +
scale_fill_distiller(palette   = palette,
direction = direction,
guide     = guide_colorbar(
barwidth  = 0.45,
barheight = 7,
ticks     = FALSE)) +
scale_x_discrete(expand = c(0, 0)) +
scale_y_discrete(expand = c(0, 0)) +
labs(title = title, subtitle = subtitle) +
theme_heatmap()
}
p1 <- make_tile(weather_annual, "days_hot_crit", "YlOrRd", 1,
"Days with extreme heat stress",
"t_dev > 20 °C  (mean daily temp > 25 °C) — count of days per year")
p2 <- make_tile(weather_annual, "days_cold_crit", "Blues", -1,
"Days with extreme cold stress",
"t_dev < −15 °C  (mean daily temp < −10 °C) — count of days per year")
p3 <- make_tile(weather_annual, "sum_heat_noncrit", "YlOrBr", 1,
"Accumulated non-critical heat  (growing degree-days)",
"Sum of t_dev for days where 0 < t_dev ≤ 20 °C — thermal budget for growth")
p4 <- make_tile(weather_annual, "sum_cold_noncrit", "PuBu", -1,
"Accumulated non-critical cold  (vernalisation budget)",
"Sum of t_dev for days where −15 ≤ t_dev < 0 °C — chilling requirement")
(p1 | p2) / (p3 | p4) +
plot_annotation(
title    = "Temperature stress metrics by region and year",
subtitle = paste0("Derived from daily Tmax / Tmin. Base temperature = ",
BASE_TEMP, " °C. Regions ordered cool → warm (W/N to E/S)."),
caption  = "Source: ukraine_daily_weather.csv",
theme    = theme(
plot.title      = element_text(face = "bold", size = 13, colour = "grey10"),
plot.subtitle   = element_text(size = 9, colour = "grey45"),
plot.caption    = element_text(size = 7.5, colour = "grey55", hjust = 0),
plot.background = element_rect(fill = "white", colour = NA)
)
)
p_tmax <- make_tile(weather_annual, "mean_tmax", "RdYlBu", -1,
"Mean daily Tmax  (°C)",
"Annual average of daily maximum temperature")
p_tmin <- make_tile(weather_annual, "mean_tmin", "RdYlBu", -1,
"Mean daily Tmin  (°C)",
"Annual average of daily minimum temperature")
p_tmean <- make_tile(weather_annual, "mean_temp", "RdYlBu", -1,
"Mean daily temperature  (°C)",
"Annual average of (Tmax + Tmin) / 2")
(p_tmax | p_tmin | p_tmean) +
plot_annotation(
title   = "Raw temperature levels by region and year",
caption = "Source: ukraine_daily_weather.csv",
theme   = theme(
plot.title      = element_text(face = "bold", size = 13, colour = "grey10"),
plot.caption    = element_text(size = 7.5, colour = "grey55", hjust = 0),
plot.background = element_rect(fill = "white", colour = NA)
)
)
make_tile(weather_annual, "total_precip", "BrBG", 1,
"Total annual precipitation  (mm)",
"Sum of daily precipitation. Green = wetter, brown = drier.") +
plot_annotation(
caption = "Source: ukraine_daily_weather.csv",
theme   = theme(
plot.background = element_rect(fill = "white", colour = NA),
plot.caption    = element_text(size = 7.5, colour = "grey55", hjust = 0)
)
)
make_tile(weather_annual, "total_et0", "YlOrRd", 1,
"Total annual ET₀  (mm/year)",
"Sum of daily reference evapotranspiration") +
plot_annotation(
title   = "Reference evapotranspiration (ET₀) by region and year",
caption = "Source: ukraine_daily_weather.csv",
theme   = theme(
plot.title      = element_text(face = "bold", size = 13, colour = "grey10"),
plot.caption    = element_text(size = 7.5, colour = "grey55", hjust = 0),
plot.background = element_rect(fill = "white", colour = NA)
)
)
make_tile(weather_annual, "mean_wind", "PuRd", 1,
"Mean annual maximum wind gusts  (m/s)",
"Annual average of daily maximum wind gust at 10 m height") +
plot_annotation(
caption = "Source: ukraine_daily_weather.csv",
theme   = theme(
plot.background = element_rect(fill = "white", colour = NA),
plot.caption    = element_text(size = 7.5, colour = "grey55", hjust = 0)
)
)
make_tile(weather_annual, "total_radiation", "YlOrRd", 1,
"Total annual solar radiation  (MJ/m²)",
"Sum of daily shortwave radiation") +
plot_annotation(
title   = "Solar radiation by region and year",
caption = "Source: ukraine_daily_weather.csv",
theme   = theme(
plot.title      = element_text(face = "bold", size = 13, colour = "grey10"),
plot.caption    = element_text(size = 7.5, colour = "grey55", hjust = 0),
plot.background = element_rect(fill = "white", colour = NA)
)
)
weather_annual |>
group_by(region) |>
summarise(
`Hot days`     = round(mean(days_hot_crit),    1),
`Cold days`    = round(mean(days_cold_crit),   1),
`Heat sum`     = round(mean(sum_heat_noncrit), 0),
`Cold sum`     = round(mean(sum_cold_noncrit), 0),
`Precip (mm)`  = round(mean(total_precip),     0),
`ET₀ (mm/yr)`  = round(mean(total_et0),        0),
`Wind (m/s)`   = round(mean(mean_wind),        1)
) |>
arrange(desc(`Hot days`)) |>
knitr::kable(caption = "Mean annual weather metrics by oblast (2013–2024, ordered by heat stress days)")
# ── 13. Soil properties ──────────────────────────────────────
vars_soil <- c("pH", "organic_matter", "total_nitrogen",
"cec", "clay", "sand", "silt")
p_soil <- soil |>
pivot_longer(cols = all_of(vars_soil),
names_to  = "property",
values_to = "value") |>
mutate(property = factor(property, levels = vars_soil)) |>
ggplot(aes(x = value,
y = reorder(oblast, value),
fill = property)) +
geom_col(width = 0.7, show.legend = FALSE) +
facet_wrap(~property, scales = "free_x", nrow = 2) +
scale_fill_manual(
values = c("#2c7bb6", "#d7191c", "#1a9641",
"#fdae61", "#abd9e9", "#756bb1", "#a6bddb")
) +
labs(
title   = "Soil properties by oblast",
caption = "Source: soil_data.csv"
) +
theme_small_multiple(base_size = 8) +
theme(
axis.text.y    = element_text(size = 6),
panel.grid.major.y = element_blank(),
panel.grid.major.x = element_line(colour = "grey90", linewidth = 0.3)
)
# ── 14. Print all plots ──────────────────────────────────────
print(p_soil)
library(tidyverse)
library(corrplot)
library(GGally)
library(car)
# ── Region name lookup (Latin weather ↔ Cyrillic crop data) ──
# Adjust spellings to match exactly what appears in your files
region_lookup <- tribble(
~region_lat,        ~region_cyr,
"Vinnytsia",        "Вінницька",
"Volyn",            "Волинська",
"Dnipropetrovsk",   "Дніпропетровська",
"Donetsk",          "Донецька",
"Zhytomyr",         "Житомирська",
"Zakarpattia",      "Закарпатська",
"Zaporizhzhia",     "Запорізька",
"Ivano-Frankivsk",  "Івано-Франківська",
"Kyiv",             "Київська",
"Kirovohrad",       "Кіровоградська",
"Luhansk",          "Луганська",
"Lviv",             "Львівська",
"Mykolaiv",         "Миколаївська",
"Odesa",            "Одеська",
"Poltava",          "Полтавська",
"Rivne",            "Рівненська",
"Sumy",             "Сумська",
"Ternopil",         "Тернопільська",
"Kharkiv",          "Харківська",
"Kherson",          "Херсонська",
"Khmelnytskyi",     "Хмельницька",
"Cherkasy",         "Черкаська",
"Chernivtsi",       "Чернівецька",
"Chernihiv",        "Чернігівська"
)
# ── Weather annual aggregation (all variables) ────────────────
weather_annual_full <- weather |>
mutate(
t_mean         = (temperature_2m_max + temperature_2m_min) / 2,
t_dev          = t_mean - 5,
days_hot_crit  = t_dev > 20,
days_cold_crit = t_dev < -15,
heat_noncrit   = if_else(t_dev > 0  & t_dev <= 20, t_dev, 0),
cold_noncrit   = if_else(t_dev >= -15 & t_dev < 0, t_dev, 0)
) |>
group_by(region, year) |>
summarise(
# Thermal stress metrics
days_hot_crit    = sum(days_hot_crit,       na.rm = TRUE),
days_cold_crit   = sum(days_cold_crit,      na.rm = TRUE),
sum_heat_noncrit = sum(heat_noncrit,        na.rm = TRUE),
sum_cold_noncrit = sum(cold_noncrit,        na.rm = TRUE),
# Raw temperature levels
mean_tmax        = mean(temperature_2m_max, na.rm = TRUE),
mean_tmin        = mean(temperature_2m_min, na.rm = TRUE),
mean_temp        = mean(t_mean,             na.rm = TRUE),
# Other weather
total_precip     = sum(precipitation_sum,            na.rm = TRUE),
total_et0        = sum(et0_fao_evapotranspiration,   na.rm = TRUE),
total_radiation  = sum(shortwave_radiation_sum,      na.rm = TRUE),
mean_wind        = mean(wind_gusts_10m_max,          na.rm = TRUE),
mean_dewpoint    = mean(dewpoint_2m_mean,            na.rm = TRUE),
# Derived
water_deficit    = sum(precipitation_sum, na.rm = TRUE) -
sum(et0_fao_evapotranspiration, na.rm = TRUE),
diurnal_range    = mean(temperature_2m_max - temperature_2m_min,
na.rm = TRUE),
.groups = "drop"
) |>
filter(year >= 2015)
# ── Harvest ratio ─────────────────────────────────────────────
harv_ratio_df <- harv |>
left_join(sown, by = c("region", "year")) |>
mutate(harv_ratio = pmin(harv_ha / sown_ha, 1.05)) |>
select(region, year, harv_ha, sown_ha, harv_ratio)
# ── Join everything on Cyrillic region names ──────────────────
panel_full <- yield |>
left_join(harv_ratio_df,  by = c("region", "year")) |>
left_join(region_lookup,  by = c("region" = "region_cyr")) |>
left_join(weather_annual_full,
by = c("region_lat" = "region", "year")) |>
left_join(soil |> rename(region_cyr = oblast) |>
left_join(region_lookup, by = c("region_cyr" = "region_cyr")),
by = c("region" = "region_cyr")) |>
filter(!is.na(yield_cpha))
cat("Panel rows:", nrow(panel_full), "\n")
cat("Regions matched:", n_distinct(panel_full$region[!is.na(panel_full$mean_temp)]), "\n")
# ── Regressor set: only variables entering the model ──────────
# Four temperature metrics + raw weather + harvest ratio
# Soil variables are time-invariant and will be absorbed by oblast
# fixed effects in the panel model, so they are excluded here.
regressors <- c(
"days_hot_crit",
"days_cold_crit",
"sum_heat_noncrit",
"sum_cold_noncrit",
"total_precip",
"total_et0",
"total_radiation",
"mean_wind",
"mean_dewpoint",
"harv_ratio"
)
# keep only columns that exist
regressors <- intersect(regressors, names(panel_full))
reg_df <- panel_full |>
select(all_of(regressors)) |>
drop_na()
# ── Display labels ────────────────────────────────────────────
reg_labels <- c(
days_hot_crit    = "Hot critical days",
days_cold_crit   = "Cold critical days",
sum_heat_noncrit = "Accum. heat",
sum_cold_noncrit = "Accum. cold",
total_precip     = "Precipitation",
total_et0        = "ET0",
total_radiation  = "Solar radiation",
mean_wind        = "Wind gusts",
mean_dewpoint    = "Dewpoint",
harv_ratio       = "Harvest ratio"
)
reg_labels <- reg_labels[regressors]
# ── 1. Correlation matrix among regressors ────────────────────
cor_reg <- cor(reg_df, use = "pairwise.complete.obs")
rownames(cor_reg) <- colnames(cor_reg) <- reg_labels
par(bg = "white")
corrplot(
cor_reg,
method      = "color",
type        = "upper",
order       = "hclust",
tl.col      = "grey15",
tl.srt      = 40,
tl.cex      = 0.85,
cl.cex      = 0.75,
addCoef.col = "grey10",
number.cex  = 0.72,
col         = colorRampPalette(c("#2c7bb6", "white", "#d7191c"))(200),
title       = "Correlation matrix among regressors",
mar         = c(0, 0, 2, 0)
)
# ── 2. VIF for the full regressor set ─────────────────────────
# OLS without fixed effects — fixed effects are not needed here
# because VIF measures regressor redundancy, not causal identification.
# Adding a constant outcome variable (yield) is enough.
vif_formula <- as.formula(
paste("yield_cpha ~", paste(regressors, collapse = " + "))
)
vif_data <- panel_full |>
select(yield_cpha, all_of(regressors)) |>
drop_na()
vif_model  <- lm(vif_formula, data = vif_data)
vif_values <- vif(vif_model)
vif_df <- tibble(
variable = names(vif_values),
VIF      = vif_values
) |>
mutate(
label   = coalesce(reg_labels[variable], variable),
concern = case_when(
VIF > 10 ~ "High — must address",
VIF > 5  ~ "Moderate — monitor",
TRUE     ~ "Acceptable"
),
concern = factor(concern,
levels = c("Acceptable",
"Moderate — monitor",
"High — must address"))
) |>
arrange(desc(VIF))
# table
knitr::kable(
vif_df |> select(label, VIF, concern),
digits  = 2,
col.names = c("Variable", "VIF", "Assessment"),
caption = "Variance Inflation Factors — full regressor set"
)
# VIF bar chart — easier to read than a table for the report
ggplot(vif_df,
aes(x = VIF,
y = fct_reorder(label, VIF),
fill = concern)) +
geom_col(width = 0.68, alpha = 0.88) +
geom_text(aes(label = round(VIF, 1)),
hjust = -0.15, size = 3, colour = "grey25") +
geom_vline(xintercept = 5,  linetype = "dashed",
colour = "grey50", linewidth = 0.5) +
geom_vline(xintercept = 10, linetype = "dashed",
colour = "#d7191c", linewidth = 0.5) +
annotate("text", x = 5.2,  y = 0.6, label = "VIF = 5",
hjust = 0, size = 2.6, colour = "grey50") +
annotate("text", x = 10.2, y = 0.6, label = "VIF = 10",
hjust = 0, size = 2.6, colour = "#d7191c") +
scale_fill_manual(values = c(
"Acceptable"           = "#1a9641",
"Moderate — monitor"   = "#fdae61",
"High — must address"  = "#d7191c"
)) +
scale_x_continuous(expand = expansion(mult = c(0, 0.15))) +
labs(
title   = "Variance Inflation Factors — full regressor set",
x       = "VIF", y = NULL, fill = NULL,
caption = "Dashed grey line = VIF 5 threshold. Dashed red line = VIF 10 threshold."
) +
theme_small_multiple(base_size = 10) +
theme(
panel.grid.major.y = element_blank(),
panel.grid.major.x = element_line(colour = "grey90", linewidth = 0.3),
axis.line.x        = element_blank(),
legend.position    = "top"
)
# ── 3. VIF after dropping the most collinear variables ─────────
# If ET0 and solar radiation both produce high VIF, drop solar radiation
# (absorbed by ET0) and recheck. This iterative approach shows clearly
# which variable is causing the inflation.
regressors_reduced <- regressors[!regressors %in% c("total_radiation",
"mean_dewpoint")]
vif_formula2 <- as.formula(
paste("yield_cpha ~", paste(regressors_reduced, collapse = " + "))
)
vif_model2  <- lm(vif_formula2,
data = panel_full |>
select(yield_cpha, all_of(regressors_reduced)) |>
drop_na())
vif_values2 <- vif(vif_model2)
vif_df2 <- tibble(
variable = names(vif_values2),
VIF      = vif_values2
) |>
mutate(
label   = coalesce(reg_labels[variable], variable),
concern = case_when(
VIF > 10 ~ "High — must address",
VIF > 5  ~ "Moderate — monitor",
TRUE     ~ "Acceptable"
),
concern = factor(concern,
levels = c("Acceptable",
"Moderate — monitor",
"High — must address"))
) |>
arrange(desc(VIF))
ggplot(vif_df2,
aes(x = VIF,
y = fct_reorder(label, VIF),
fill = concern)) +
geom_col(width = 0.68, alpha = 0.88) +
geom_text(aes(label = round(VIF, 1)),
hjust = -0.15, size = 3, colour = "grey25") +
geom_vline(xintercept = 5,  linetype = "dashed",
colour = "grey50", linewidth = 0.5) +
geom_vline(xintercept = 10, linetype = "dashed",
colour = "#d7191c", linewidth = 0.5) +
annotate("text", x = 5.2,  y = 0.6, label = "VIF = 5",
hjust = 0, size = 2.6, colour = "grey50") +
annotate("text", x = 10.2, y = 0.6, label = "VIF = 10",
hjust = 0, size = 2.6, colour = "#d7191c") +
scale_fill_manual(values = c(
"Acceptable"           = "#1a9641",
"Moderate — monitor"   = "#fdae61",
"High — must address"  = "#d7191c"
)) +
scale_x_continuous(expand = expansion(mult = c(0, 0.15))) +
labs(
title   = "VIF after removing solar radiation and dewpoint",
subtitle = "Shows whether removing the most collinear variables resolves inflation in the remaining set.",
x       = "VIF", y = NULL, fill = NULL,
caption = "Dashed grey line = VIF 5. Dashed red line = VIF 10."
) +
theme_small_multiple(base_size = 10) +
theme(
panel.grid.major.y = element_blank(),
panel.grid.major.x = element_line(colour = "grey90", linewidth = 0.3),
axis.line.x        = element_blank(),
legend.position    = "top"
)
library(tidyverse)
library(fixest)
library(patchwork)
# Function to test different base temperatures
test_base_temp <- function(base_temp, data, phase = "full") {
# Select appropriate weather data based on phase
if (phase == "full") {
weather_data <- weather_full
suffix <- ""
} else if (phase == "early") {
weather_data <- weather_early
suffix <- "_early"
} else if (phase == "late") {
weather_data <- weather_late
suffix <- "_late"
} else {
weather_data <- weather_gs
suffix <- "_gs"
}
# Recalculate thermal aggregates with new base temperature
weather_recalc <- weather |>
mutate(
t_mean = (temperature_2m_max + temperature_2m_min) / 2,
t_dev = t_mean - base_temp,
heat_noncrit = if_else(t_dev > 0 & t_dev <= 20, t_dev, 0),
cold_noncrit = if_else(t_dev >= -15 & t_dev < 0, t_dev, 0)
) |>
group_by(region, year) |>
summarise(
sum_heat_noncrit = sum(heat_noncrit, na.rm = TRUE),
sum_cold_noncrit = sum(cold_noncrit, na.rm = TRUE),
.groups = "drop"
) |>
rename_with(~ paste0(.x, suffix), -c(region, year))
# Join with panel
panel_test <- panel_model |>
select(-ends_with(paste0(suffix))) |>
left_join(weather_recalc, by = c("region_lat" = "region", "year"))
# Estimate model
if (phase == "full") {
model <- feols(
yield_cpha ~ sum_heat_noncrit + sum_cold_noncrit +
days_hot_crit + days_cold_crit +
total_precip + total_et0 + mean_wind + water_deficit +
log_sown + war_east | region_id + year_id,
data = panel_test, cluster = ~region_id
)
} else if (phase == "early") {
model <- feols(
yield_cpha ~ sum_heat_noncrit_early + sum_cold_noncrit_early +
days_hot_crit_early + days_cold_crit_early +
total_precip_early + total_et0_early +
mean_wind_early + water_deficit_early +
war_east | region_id + year_id,
data = panel_test, cluster = ~region_id
)
} else if (phase == "late") {
model <- feols(
yield_cpha ~ sum_heat_noncrit_late + sum_cold_noncrit_late +
days_hot_crit_late + days_cold_crit_late +
total_precip_late + total_et0_late +
mean_wind_late + water_deficit_late +
war_east | region_id + year_id,
data = panel_test, cluster = ~region_id
)
} else {
model <- feols(
yield_cpha ~ sum_heat_noncrit_gs + sum_cold_noncrit_gs +
days_hot_crit_gs + days_cold_crit_gs +
total_precip_gs + total_et0_gs +
mean_wind_gs + water_deficit_gs +
war_east | region_id + year_id,
data = panel_test, cluster = ~region_id
)
}
return(data.frame(
base_temp = base_temp,
phase = phase,
AIC = AIC(model),
BIC = BIC(model),
r2_within = r2(model)[["wr2"]]
))
}
# Test base temperatures for each phase
base_temps <- seq(0, 10, by = 1)
phases <- c("full", "early", "late", "gs")
results_base <- expand.grid(base_temp = base_temps, phase = phases) |>
rowwise() |>
mutate(results = list(test_base_temp(base_temp, phase))) |>
unnest(cols = c(results))
