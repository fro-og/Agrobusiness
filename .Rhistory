# Focus on the variables most likely to enter the regression
ggpairs(
panel_full |>
select(
Yield            = yield_cpha,
`Hot days`       = days_hot_crit,
`Cold days`      = days_cold_crit,
`Heat sum`       = sum_heat_noncrit,
`Cold sum`       = sum_cold_noncrit,
Precipitation    = total_precip,
ET₀              = total_et0,
vif_model <- lm(
yield_cpha ~ days_hot_crit + days_cold_crit +
sum_heat_noncrit + sum_cold_noncrit +
total_precip + total_et0 + total_radiation +
mean_wind + water_deficit + harv_ratio +
pH + organic_matter + cec + clay + sand,
data = panel_full |> drop_na(yield_cpha, days_hot_crit, total_et0,
harv_ratio, pH, clay)
)
weather_vars <- panel_full |>
select(
`Hot critical days`   = days_hot_crit,
`Cold critical days`  = days_cold_crit,
`Heat sum`            = sum_heat_noncrit,
`Cold sum`            = sum_cold_noncrit,
`Mean temp`           = mean_temp,
`Diurnal range`       = diurnal_range,
`Precipitation`       = total_precip,
`ET₀`                 = total_et0,
`Solar radiation`     = total_radiation,
`Wind gusts`          = mean_wind,
`Dewpoint`            = mean_dewpoint,
`Water deficit`       = water_deficit
) |>
drop_na()
cor_weather <- cor(weather_vars, use = "pairwise.complete.obs")
par(bg = "white", mar = c(0, 0, 3, 0))
corrplot(
cor_weather,
method      = "color",
type        = "upper",
order       = "hclust",
tl.col      = "grey15",
tl.srt      = 40,
tl.cex      = 0.82,
cl.cex      = 0.75,
addCoef.col = "grey10",
number.cex  = 0.65,
col         = colorRampPalette(c("#2c7bb6", "white", "#d7191c"))(200),
title       = "Correlations among weather variables",
mar         = c(0, 0, 2, 0)
)
# ── Variables actually present in the data ────────────────────
# Raw weather (aggregated annually):
#   total_precip, total_et0, total_radiation, mean_wind, mean_dewpoint
# Calculated from daily temperature:
#   days_hot_crit, days_cold_crit, sum_heat_noncrit, sum_cold_noncrit
# Area:
#   harv_ha, sown_ha, harv_ratio
# Soil (time-invariant):
#   pH, organic_matter, total_nitrogen, cec, clay, sand, silt, c_n_ratio
candidates <- c(
# four derived temperature metrics
"days_hot_crit", "days_cold_crit",
"sum_heat_noncrit", "sum_cold_noncrit",
# raw weather aggregates
"total_precip", "total_et0", "total_radiation",
"mean_wind", "mean_dewpoint",
# area variables
"harv_ha", "sown_ha", "harv_ratio",
# soil
"pH", "organic_matter", "total_nitrogen", "cec",
"clay", "sand", "silt", "c_n_ratio"
)
# keep only columns that actually exist in panel_full
candidates <- intersect(candidates, names(panel_full))
# compute r with yield individually — pairwise so soil NAs
# do not drop weather rows
yield_cors <- map_dfr(candidates, function(col) {
x  <- panel_full[[col]]
y  <- panel_full[["yield_cpha"]]
ok <- !is.na(x) & !is.na(y)
tibble(
variable = col,
r        = if (sum(ok) > 2) cor(x[ok], y[ok]) else NA_real_,
n        = sum(ok)
)
}) |>
filter(!is.na(r)) |>
mutate(direction = if_else(r >= 0, "Positive", "Negative"))
# display labels
nice_labels <- c(
days_hot_crit    = "Hot critical days",
days_cold_crit   = "Cold critical days",
sum_heat_noncrit = "Accumulated heat (non-crit.)",
sum_cold_noncrit = "Accumulated cold (non-crit.)",
total_precip     = "Total precipitation",
total_et0        = "Total ET0",
total_radiation  = "Solar radiation",
mean_wind        = "Wind gusts",
mean_dewpoint    = "Dewpoint",
harv_ha          = "Harvested area",
sown_ha          = "Sown area",
harv_ratio       = "Harvest ratio",
pH               = "Soil pH",
organic_matter   = "Organic matter",
total_nitrogen   = "Total nitrogen",
cec              = "CEC",
clay             = "Clay content",
sand             = "Sand content",
silt             = "Silt content",
c_n_ratio        = "C:N ratio"
)
yield_cors <- yield_cors |>
mutate(
label = coalesce(nice_labels[variable], variable),
label = fct_reorder(label, r)
)
ggplot(yield_cors, aes(x = r, y = label, fill = direction)) +
geom_col(width = 0.68, alpha = 0.85) +
geom_text(
aes(label = sprintf("%.2f", r),
hjust = if_else(r >= 0, -0.15, 1.15)),
size = 2.9, colour = "grey25"
) +
geom_vline(xintercept = c(-0.3, 0.3),
linetype = "dashed", colour = "grey60", linewidth = 0.4) +
geom_vline(xintercept = 0, colour = "grey30", linewidth = 0.5) +
scale_fill_manual(values = c(Positive = "#d7191c", Negative = "#2c7bb6")) +
scale_x_continuous(
limits = c(-1, 1),
breaks = seq(-1, 1, 0.25),
expand = expansion(mult = c(0.05, 0.14))
) +
labs(
title    = "Pearson correlation of each variable with yield",
subtitle = "Variables: four derived temperature metrics, raw weather aggregates, area, and soil.\nDashed lines at r = +/-0.30. Correlations computed pairwise.",
x        = "Pearson r", y = NULL, fill = NULL,
caption  = "Panel data 2015-2025. Soil variables are time-invariant (repeated per year)."
) +
theme_small_multiple(base_size = 10) +
theme(
panel.grid.major.y = element_blank(),
panel.grid.major.x = element_line(colour = "grey90", linewidth = 0.3),
axis.line.x        = element_blank(),
legend.position    = "top"
)
# named vector: raw_name = "Display label"
col_map <- c(
"yield_cpha"       = "Yield",
"days_hot_crit"    = "Hot critical days",
"days_cold_crit"   = "Cold critical days",
"sum_heat_noncrit" = "Accum. heat",
"sum_cold_noncrit" = "Accum. cold",
"total_precip"     = "Precipitation",
"total_et0"        = "ET0",
"total_radiation"  = "Solar radiation",
"mean_wind"        = "Wind gusts",
"mean_dewpoint"    = "Dewpoint",
"harv_ha"          = "Harv. area",
"sown_ha"          = "Sown area",
"harv_ratio"       = "Harv. ratio",
"pH"               = "pH",
"organic_matter"   = "Org. matter",
"total_nitrogen"   = "Nitrogen",
"cec"              = "CEC",
"clay"             = "Clay",
"sand"             = "Sand",
"silt"             = "Silt",
"c_n_ratio"        = "C:N ratio"
)
# keep only columns present in panel_full
col_map <- col_map[names(col_map) %in% names(panel_full)]
mat_df <- panel_full |>
select(all_of(names(col_map))) |>
set_names(col_map)
# pairwise correlation — handles soil NAs without dropping weather rows
cor_all <- cor(mat_df, use = "pairwise.complete.obs")
# remove any rows/cols that are all NA (failed joins)
keep <- rowSums(is.na(cor_all)) < ncol(cor_all)
cor_all <- cor_all[keep, keep]
par(bg = "white")
corrplot(
cor_all,
method      = "color",
type        = "upper",
order       = "hclust",
tl.col      = "grey15",
tl.srt      = 45,
tl.cex      = 0.78,
cl.cex      = 0.72,
addCoef.col = "grey10",
number.cex  = 0.58,
col         = colorRampPalette(c("#2c7bb6", "white", "#d7191c"))(200),
title       = "Full correlation matrix - all research variables",
mar         = c(0, 0, 2, 0)
)
library(corrplot)
library(car)
# ── Regressor set: only variables entering the model ──────────
# Four temperature metrics + raw weather + harvest ratio
# Soil variables are time-invariant and will be absorbed by oblast
# fixed effects in the panel model, so they are excluded here.
regressors <- c(
"days_hot_crit",
"days_cold_crit",
"sum_heat_noncrit",
"sum_cold_noncrit",
"total_precip",
"total_et0",
"total_radiation",
"mean_wind",
"mean_dewpoint",
"harv_ratio"
)
# keep only columns that exist
regressors <- intersect(regressors, names(panel_full))
reg_df <- panel_full |>
select(all_of(regressors)) |>
drop_na()
cat("Observations used for collinearity diagnostics:", nrow(reg_df), "\n")
# ── Display labels ────────────────────────────────────────────
reg_labels <- c(
days_hot_crit    = "Hot critical days",
days_cold_crit   = "Cold critical days",
sum_heat_noncrit = "Accum. heat",
sum_cold_noncrit = "Accum. cold",
total_precip     = "Precipitation",
total_et0        = "ET0",
total_radiation  = "Solar radiation",
mean_wind        = "Wind gusts",
mean_dewpoint    = "Dewpoint",
harv_ratio       = "Harvest ratio"
)
reg_labels <- reg_labels[regressors]
# ── 1. Correlation matrix among regressors ────────────────────
cor_reg <- cor(reg_df, use = "pairwise.complete.obs")
rownames(cor_reg) <- colnames(cor_reg) <- reg_labels
par(bg = "white")
corrplot(
cor_reg,
method      = "color",
type        = "upper",
order       = "hclust",
tl.col      = "grey15",
tl.srt      = 40,
tl.cex      = 0.85,
cl.cex      = 0.75,
addCoef.col = "grey10",
number.cex  = 0.72,
col         = colorRampPalette(c("#2c7bb6", "white", "#d7191c"))(200),
title       = "Correlation matrix among regressors",
mar         = c(0, 0, 2, 0)
)
# ── 2. VIF for the full regressor set ─────────────────────────
# OLS without fixed effects — fixed effects are not needed here
# because VIF measures regressor redundancy, not causal identification.
# Adding a constant outcome variable (yield) is enough.
vif_formula <- as.formula(
paste("yield_cpha ~", paste(regressors, collapse = " + "))
)
vif_data <- panel_full |>
select(yield_cpha, all_of(regressors)) |>
drop_na()
vif_model  <- lm(vif_formula, data = vif_data)
vif_values <- vif(vif_model)
vif_df <- tibble(
variable = names(vif_values),
VIF      = vif_values
) |>
mutate(
label   = coalesce(reg_labels[variable], variable),
concern = case_when(
VIF > 10 ~ "High — must address",
VIF > 5  ~ "Moderate — monitor",
TRUE     ~ "Acceptable"
),
concern = factor(concern,
levels = c("Acceptable",
"Moderate — monitor",
"High — must address"))
) |>
arrange(desc(VIF))
# table
knitr::kable(
vif_df |> select(label, VIF, concern),
digits  = 2,
col.names = c("Variable", "VIF", "Assessment"),
caption = "Variance Inflation Factors — full regressor set"
)
# VIF bar chart — easier to read than a table for the report
ggplot(vif_df,
aes(x = VIF,
y = fct_reorder(label, VIF),
fill = concern)) +
geom_col(width = 0.68, alpha = 0.88) +
geom_text(aes(label = round(VIF, 1)),
hjust = -0.15, size = 3, colour = "grey25") +
geom_vline(xintercept = 5,  linetype = "dashed",
colour = "grey50", linewidth = 0.5) +
geom_vline(xintercept = 10, linetype = "dashed",
colour = "#d7191c", linewidth = 0.5) +
annotate("text", x = 5.2,  y = 0.6, label = "VIF = 5",
hjust = 0, size = 2.6, colour = "grey50") +
annotate("text", x = 10.2, y = 0.6, label = "VIF = 10",
hjust = 0, size = 2.6, colour = "#d7191c") +
scale_fill_manual(values = c(
"Acceptable"           = "#1a9641",
"Moderate — monitor"   = "#fdae61",
"High — must address"  = "#d7191c"
)) +
scale_x_continuous(expand = expansion(mult = c(0, 0.15))) +
labs(
title   = "Variance Inflation Factors — full regressor set",
x       = "VIF", y = NULL, fill = NULL,
caption = "Dashed grey line = VIF 5 threshold. Dashed red line = VIF 10 threshold."
) +
theme_small_multiple(base_size = 10) +
theme(
panel.grid.major.y = element_blank(),
panel.grid.major.x = element_line(colour = "grey90", linewidth = 0.3),
axis.line.x        = element_blank(),
legend.position    = "top"
)
# ── 3. VIF after dropping the most collinear variables ─────────
# If ET0 and solar radiation both produce high VIF, drop solar radiation
# (absorbed by ET0) and recheck. This iterative approach shows clearly
# which variable is causing the inflation.
regressors_reduced <- regressors[!regressors %in% c("total_radiation",
"mean_dewpoint")]
vif_formula2 <- as.formula(
paste("yield_cpha ~", paste(regressors_reduced, collapse = " + "))
)
vif_model2  <- lm(vif_formula2,
data = panel_full |>
select(yield_cpha, all_of(regressors_reduced)) |>
drop_na())
vif_values2 <- vif(vif_model2)
vif_df2 <- tibble(
variable = names(vif_values2),
VIF      = vif_values2
) |>
mutate(
label   = coalesce(reg_labels[variable], variable),
concern = case_when(
VIF > 10 ~ "High — must address",
VIF > 5  ~ "Moderate — monitor",
TRUE     ~ "Acceptable"
),
concern = factor(concern,
levels = c("Acceptable",
"Moderate — monitor",
"High — must address"))
) |>
arrange(desc(VIF))
ggplot(vif_df2,
aes(x = VIF,
y = fct_reorder(label, VIF),
fill = concern)) +
geom_col(width = 0.68, alpha = 0.88) +
geom_text(aes(label = round(VIF, 1)),
hjust = -0.15, size = 3, colour = "grey25") +
geom_vline(xintercept = 5,  linetype = "dashed",
colour = "grey50", linewidth = 0.5) +
geom_vline(xintercept = 10, linetype = "dashed",
colour = "#d7191c", linewidth = 0.5) +
annotate("text", x = 5.2,  y = 0.6, label = "VIF = 5",
hjust = 0, size = 2.6, colour = "grey50") +
annotate("text", x = 10.2, y = 0.6, label = "VIF = 10",
hjust = 0, size = 2.6, colour = "#d7191c") +
scale_fill_manual(values = c(
"Acceptable"           = "#1a9641",
"Moderate — monitor"   = "#fdae61",
"High — must address"  = "#d7191c"
)) +
scale_x_continuous(expand = expansion(mult = c(0, 0.15))) +
labs(
title   = "VIF after removing solar radiation and dewpoint",
subtitle = "Shows whether removing the most collinear variables resolves inflation in the remaining set.",
x       = "VIF", y = NULL, fill = NULL,
caption = "Dashed grey line = VIF 5. Dashed red line = VIF 10."
) +
theme_small_multiple(base_size = 10) +
theme(
panel.grid.major.y = element_blank(),
panel.grid.major.x = element_line(colour = "grey90", linewidth = 0.3),
axis.line.x        = element_blank(),
legend.position    = "top"
)
